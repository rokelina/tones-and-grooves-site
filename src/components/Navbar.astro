<style>
    .navbar {
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #282828;
        border-bottom: 1px solid #444;
        padding: 0.5rem 0;
    }

    .navbar-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
        display: flex;
        justify-content: space-between; /* Space out social and nav links */
        align-items: center;
    }

    .social-links {
        display: flex;
        gap: 1.2rem;
        align-items: center;
    }

    .social-links a {
        display: flex;
        align-items: center;
        transition: opacity 0.2s, transform 0.2s;
    }

    .social-links a:hover {
        opacity: 0.8;
        transform: scale(1.05);
    }

    .links {
        display: flex;
        gap: 1.5rem;
    }

    .links a {
        color: white;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
    }

    .links a:hover {
        color: grey;
    }

    svg {
        width: 2rem;
        height: 2rem;
    }
</style>
