<style>
    .navbar {
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #303030;
        border-bottom: 1px solid #444;
        padding: 1rem 0;
    }

    .navbar-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
        display: flex;
        justify-content: flex-end; /* Align to the right */
        align-items: center;
    }

    .links {
        display: flex;
        gap: 1.5rem;
    }

    .links a {
        color: #ddd;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
    }

    .links a:hover {
        color: white;
    }
</style>
