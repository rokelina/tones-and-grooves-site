---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Info - Drum Studio">
	<main>
		<h1>Lesson Details & Rates</h1>
		<div class="info-content">
			<ul>
				<li><strong>Location:</strong> The studio is located in the Shoreview area, within walking distance of Chippewa Middle School.</li>
				<li><strong>Format:</strong> Lessons are 30 minutes long and available in-person or online.</li>
				<li><strong>Rate:</strong> $35 per lesson, due at the time of the lesson.</li>
				<li><strong>Cancellation Policy:</strong> Please provide at least 24 hours' notice if you need to cancel or reschedule a lesson. Cancellations made with less than 24 hours' notice are subject to the full lesson fee.</li>
				<li><strong>Practice:</strong> To see progress and get the most out of our time, students are expected to practice at least 15 minutes a day.</li>
			</ul>
		</div>
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.6;
	}
	.info-content ul {
		list-style-type: disc;
		padding-left: 1.5rem;
		font-size: 1.1rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.info-content strong {
		color: #fff;
		font-weight: 600;
	}
	.info-content li {
		color: #e0e0e0;
	}
</style>
