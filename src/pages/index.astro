---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import drumsetImg from '../images/drumset_landing_page_3_low_small.jpg';
import logoImg from '../images/logo_landing_white_final_small.png';
---

<Layout title="Tones And Grooves Drum Studio">
	<main>
		<div class="logo-container">
			<Image src={logoImg} alt="Business Logo" class="logo" loading="eager"
  fetchpriority="high"/>
		</div>
		<div class="text-container">
			<h1>Tones And Grooves</h1>
			<h4 style="font-style: italic; font-weight: 300;">Drum lessons in Shoreview, MN tailored to all ages and skill levels</h4>
		</div>
	</main>
	<div class="hero-image-container">
		<Image src={drumsetImg} alt="Drumset" class="hero-image" loading="eager"
  fetchpriority="high"/>
	</div>
</Layout>

<style>
	.hero-image-container {
		width: 100%;
		height: 65vh;
		flex-shrink: 0;
		overflow: hidden;
	}
	.hero-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		aspect-ratio: 16 / 9;
		filter: contrast(1.1)
	}
	main {
		flex: 1;
		margin: 0 auto;
		padding: 1rem;
		width: 1200px;
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.6;
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 2rem;
	}
	h1, h4 {
		margin: 0;
	}
	.logo-container {
		padding-right: 2rem;
	}
	.logo {
		width: 10rem;
		height: auto;
	}

	/* Responsive Styles */
	@media (max-width: 768px) {
		.hero-image-container {
			height: 50vh;
		}
		main {
			flex-direction: column;
			text-align: center;
			gap: 1.5rem;
			font-size: 18px;
		}
		h1 {
			font-size: 2.2rem;
		}
		h4 {
			font-size: 1.1rem;
		}
		.logo-container {
			padding-right: 0;
		}
		.logo {
			width: 8rem;
		}
	}

	@media (max-width: 480px) {
		.hero-image-container {
			height: 45vh;
		}
		main {
			gap: 1rem;
			font-size: 16px;
		}
		h1 {
			font-size: 1.8rem;
		}
		h4 {
			font-size: 1rem;
		}
		.logo {
			width: 7rem;
		}
	}

	@media (min-width: 1440px) {
		main {
			width: 1200px;
			gap: 4rem;
		}
		h1 {
			font-size: 3.5rem;
			letter-spacing: 2px;
		}
		h4 {
			font-size: 1.4rem;
			letter-spacing: 1px;
		}
		.logo {
			width: 14rem;
		}
	}
</style>
