---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import drumsetImg from '../images/drumset_landing_page_3_low.jpg';
import logoImg from '../images/logo_landing_white_final.png';
---

<Layout title="Drum Studio">
	<div class="hero-image-container">
		<Image src={drumsetImg} alt="Drumset" class="hero-image" />
	</div>
	<main>
		<div class="logo-container">
			<Image src={logoImg} alt="Business Logo" class="logo" />
		</div>
		<div class="text-container">
			<h1>Tones And Grooves</h1>
			<h4 style="font-style: italic; font-weight: 300;">Drum lessons in Shoreview, MN tailored to all ages and skill levels</h4>
		</div>
	</main>
</Layout>

<style>
	.hero-image-container {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100vw;
		height: 65vh;
		z-index: -1;
		overflow: hidden;
	}
	.hero-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		aspect-ratio: 16 / 9;
		filter: contrast(1.1)
	}
	main {
		margin: auto;
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.6;
		display: flex;
		align-items: center;
		gap: 2rem;
	}
	h1, h4 {
		margin: 0;
	}
	.logo-container {
		padding-right: 2rem;
	}
	.logo {
		width: 10rem;
		height: auto;
	}
</style>
